// Test WITH when guards
~import "$vaxis"

~vaxis:run(title: "Test Poll")
| ready t |> vaxis:poll()
    | key k when (k.codepoint == 'q') |> vaxis:cleanup(handle: t.tty)
        | done |> _
    | key k |> vaxis:cleanup(handle: t.tty)
        | done |> _
    | resize _ |> vaxis:cleanup(handle: t.tty)
        | done |> _
    | focus_in |> vaxis:cleanup(handle: t.tty)
        | done |> _
    | focus_out |> vaxis:cleanup(handle: t.tty)
        | done |> _
    | quit |> _
| err _ |> _
