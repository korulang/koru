// Koru Standard Library: Type Declarations
// =========================================
//
// This module provides events for declaring Zig types that Koru can reason about.
// All events use explicit module paths (no keywords) to keep things clear.
//
// Koru doesn't have a built-in type system - Zig does all the type checking.
// But by declaring types through these events, Koru can:
//   - Track types in a registry for transforms
//   - Apply layout annotations like [soa], [packed]
//   - Enable data-oriented patterns (ECS, etc.)
//
// USAGE:
//   ~import "$std/types"
//
//   ~std.types:struct(Player) { name: []const u8, health: i32 }
//   ~[pub]std.types:struct(Position) { x: f32, y: f32 }
//
//   ~std.types:enum(Color) { red, green, blue }
//   ~[pub]std.types:enum(State) { idle, running, jumping }
//
//   ~std.types:union(Value) { int: i32, float: f32, none }
//
// Future annotations:
//   ~[pub|soa]std.types:struct(Enemies) { hp: i32, x: f32, y: f32 }
//   ~[packed]std.types:struct(NetworkPacket) { ... }
//
// NOTE: For const/var declarations, use raw Zig or ~const from control.kz

~[comptime|runtime]

const std = @import("std");

// ============================================================================
// TYPE DECLARATIONS
// ============================================================================

// Declare a Zig struct type
// [pub] - emits `pub const Name = struct { ... }`
// [soa] - (future) emits struct-of-arrays layout
// [packed] - (future) emits packed struct
~[keyword|comptime|transform]pub event struct {
    expr: Expression,
    source: Source,
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator
}
| transformed { program: *const Program }

~[norun]pub event struct.impl { name: []const u8 }

~proc struct {
    const ast = @import("ast");
    const ast_functional = @import("ast_functional");

    // Get the flow from the item
    const flow = if (item.* == .flow)
        &item.flow
    else
        return .{ .transformed = .{ .program = program } };

    // Parse type name from expr (strip quotes if present)
    var type_name = expr;
    if (type_name.len >= 2 and type_name[0] == '"' and type_name[type_name.len - 1] == '"') {
        type_name = type_name[1 .. type_name.len - 1];
    }

    // Check for [pub] annotation
    var is_pub = false;
    for (flow.annotations) |ann| {
        if (std.mem.eql(u8, ann, "pub")) {
            is_pub = true;
            break;
        }
    }

    const pub_prefix = if (is_pub) "pub " else "";

    // ==========================================================================
    // STRUCT HANDLING
    // ==========================================================================
    // Two cases:
    // 1. "Option<T>"  -> generic definition, store but don't emit
    // 2. "Player"     -> normal struct, emit as-is
    //
    // NOTE: For instantiation (e.g., "OptionalInt = Option<i32>"), use ~type

    // Helper: format body with consistent indentation (inline)
    const formatBodyFn = struct {
        fn format(alloc: std.mem.Allocator, text: []const u8) []const u8 {
            var needed: usize = 0;
            var lines_iter = std.mem.splitScalar(u8, text, '\n');
            while (lines_iter.next()) |line| {
                const trimmed = std.mem.trim(u8, line, " \t\r");
                if (trimmed.len == 0) continue;
                needed += 8 + trimmed.len + 1;
            }

            const body_buf = alloc.alloc(u8, needed) catch unreachable;
            var write_pos: usize = 0;
            var lines2_iter = std.mem.splitScalar(u8, text, '\n');
            while (lines2_iter.next()) |line| {
                const trimmed = std.mem.trim(u8, line, " \t\r");
                if (trimmed.len == 0) continue;
                @memcpy(body_buf[write_pos..][0..8], "        ");
                write_pos += 8;
                @memcpy(body_buf[write_pos..][0..trimmed.len], trimmed);
                write_pos += trimmed.len;
                body_buf[write_pos] = '\n';
                write_pos += 1;
            }
            return body_buf[0..write_pos];
        }
    }.format;

    // Check for generic definition: contains <
    var has_angle = false;
    for (type_name) |c| {
        if (c == '<') {
            has_angle = true;
            break;
        }
    }

    if (has_angle) {
        // GENERIC DEFINITION: "Option<T>" - don't emit Zig code
        // Store the definition as a special comment that ~type can parse
        // Format: // __GENERIC__:Name<Params>:Body
        const escaped_body = std.mem.replaceOwned(u8, allocator, source.text, "\n", "\\n") catch unreachable;
        const code = std.fmt.allocPrint(
            allocator,
            "// __GENERIC__:{s}:{s}",
            .{ type_name, escaped_body }
        ) catch unreachable;

        const inline_code_item = ast.Item{
            .inline_code = ast.InlineCode{
                .code = code,
                .location = flow.location,
                .module = allocator.dupe(u8, flow.module) catch unreachable,
            },
        };

        const maybe_new_program = ast_functional.replaceFlowRecursive(allocator, program, flow, inline_code_item) catch unreachable;
        if (maybe_new_program) |new_program| {
            const result = allocator.create(ast.Program) catch unreachable;
            result.* = new_program;
            return .{ .transformed = .{ .program = result } };
        }
        return .{ .transformed = .{ .program = program } };
    }

    // NORMAL STRUCT: no generics, emit as-is
    const body = formatBodyFn(allocator, source.text);
    const code = std.fmt.allocPrint(
        allocator,
        "{s}const {s} = struct {{\n{s}    }};",
        .{ pub_prefix, type_name, body }
    ) catch unreachable;

    const inline_code_item = ast.Item{
        .inline_code = ast.InlineCode{
            .code = code,
            .location = flow.location,
            .module = allocator.dupe(u8, flow.module) catch unreachable,
        },
    };

    const maybe_new_program = ast_functional.replaceFlowRecursive(allocator, program, flow, inline_code_item) catch unreachable;
    if (maybe_new_program) |new_program| {
        const result = allocator.create(ast.Program) catch unreachable;
        result.* = new_program;
        return .{ .transformed = .{ .program = result } };
    }
    return .{ .transformed = .{ .program = program } };
}

// Declare a Zig enum type
~[comptime|norun]pub event enum { expr: Expression, source: Source }

~proc enum {
    // Emits: `pub const Name = enum { ...source... };` (or without pub)
}

// Declare a Zig union type
~[comptime|norun]pub event union { expr: Expression, source: Source }

~proc union {
    // Emits: `pub const Name = union { ...source... };` (or without pub)
    // Or: `pub const Name = union(EnumType) { ...source... };` for tagged unions
}

// ============================================================================
// NOMINAL PRIMITIVE TYPES
// ============================================================================
// These create distinct named types that wrap Zig primitives.
// Koru tracks them as separate types for type checking.
//
// USAGE:
//   ~string(EmailAddress)    // wraps []const u8
//   ~int(UserId)             // wraps i64
//   ~float(Temperature)      // wraps f64
//   ~bool(IsActive)          // wraps bool

// Declare a nominal string type (wraps []const u8)
~[keyword|comptime|transform]pub event string {
    expr: Expression,
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator
}
| transformed { program: *const Program }

~proc string {
    const ast = @import("ast");
    const ast_functional = @import("ast_functional");

    const flow = if (item.* == .flow)
        &item.flow
    else
        return .{ .transformed = .{ .program = program } };

    // Parse type name from expr (strip quotes if present)
    var type_name = expr;
    if (type_name.len >= 2 and type_name[0] == '"' and type_name[type_name.len - 1] == '"') {
        type_name = type_name[1 .. type_name.len - 1];
    }

    // Check for [pub] annotation
    var is_pub = false;
    for (flow.annotations) |ann| {
        if (std.mem.eql(u8, ann, "pub")) {
            is_pub = true;
            break;
        }
    }

    const pub_prefix = if (is_pub) "pub " else "";

    // Emit: const EmailAddress = []const u8;
    const code = std.fmt.allocPrint(
        allocator,
        "{s}const {s} = []const u8;",
        .{ pub_prefix, type_name }
    ) catch unreachable;

    const inline_code_item = ast.Item{
        .inline_code = ast.InlineCode{
            .code = code,
            .location = flow.location,
            .module = allocator.dupe(u8, flow.module) catch unreachable,
        },
    };

    const maybe_new_program = ast_functional.replaceFlowRecursive(allocator, program, flow, inline_code_item) catch unreachable;
    if (maybe_new_program) |new_program| {
        const result = allocator.create(ast.Program) catch unreachable;
        result.* = new_program;
        return .{ .transformed = .{ .program = result } };
    }
    return .{ .transformed = .{ .program = program } };
}

// Declare a nominal integer type (wraps i64)
~[keyword|comptime|transform]pub event int {
    expr: Expression,
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator
}
| transformed { program: *const Program }

~proc int {
    const ast = @import("ast");
    const ast_functional = @import("ast_functional");

    const flow = if (item.* == .flow)
        &item.flow
    else
        return .{ .transformed = .{ .program = program } };

    var type_name = expr;
    if (type_name.len >= 2 and type_name[0] == '"' and type_name[type_name.len - 1] == '"') {
        type_name = type_name[1 .. type_name.len - 1];
    }

    var is_pub = false;
    for (flow.annotations) |ann| {
        if (std.mem.eql(u8, ann, "pub")) {
            is_pub = true;
            break;
        }
    }

    const pub_prefix = if (is_pub) "pub " else "";

    // Emit: const UserId = i64;
    const code = std.fmt.allocPrint(
        allocator,
        "{s}const {s} = i64;",
        .{ pub_prefix, type_name }
    ) catch unreachable;

    const inline_code_item = ast.Item{
        .inline_code = ast.InlineCode{
            .code = code,
            .location = flow.location,
            .module = allocator.dupe(u8, flow.module) catch unreachable,
