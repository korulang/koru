// Declare a nominal bool type (wraps bool)
~[keyword|comptime|transform]pub event bool {
    expr: Expression,
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator
}
| transformed { program: *const Program }

~proc bool {
