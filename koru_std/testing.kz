// Koru Testing Framework
//
// Compiler-guided test development with automatic mock detection.
//
// Usage:
//   ~test(User cannot withdraw more than balance) {
//       ~account.balance = amount 50
//       ~app:withdraw(amount: 100)
//       | insufficient_funds |> assert.ok()
//   }
//
// The compiler:
//   1. Traces the flow to find impure events
//   2. Errors if impure event not mocked
//   3. Errors if mock is unused
//   4. Generates Zig test block

const std = @import("std");

// =============================================================================
// Test Declaration
// =============================================================================

// Main test event - takes name as Expression, body as Source
// Transform generates Zig test blocks using real emitter infrastructure
~[keyword|comptime|transform] pub event test {
    expr: Expression,
    source: Source,
    invocation: *const Invocation,
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator
}
| transformed { program: *const Program }

// Test transform - generates proper Zig test blocks
// Uses real emitter infrastructure for code generation
~proc test {
    const std_import = @import("std");
    const ast = @import("ast");
    const ast_functional = @import("ast_functional");
    const parser_impl = @import("parser");
    const emitter_helpers = @import("emitter_helpers");

    // Get the flow from the item
    const flow = if (item.* == .flow)
        &item.flow
    else if (item.* == .subflow_impl and item.subflow_impl.body == .flow)
        &item.subflow_impl.body.flow
    else
        return .{ .transformed = .{ .program = program } };

    const is_top_level = (invocation == &flow.invocation);
    if (!is_top_level) {
        return .{ .transformed = .{ .program = program } };
    }

    // Get test name from expr parameter
    const test_name = expr;

    // Storage for parsed items
    var cloned_mocks = std_import.ArrayList(ast.Item).initCapacity(allocator, 8) catch unreachable;
    var cloned_flows = std_import.ArrayList(ast.Item).initCapacity(allocator, 8) catch unreachable;

    // Parse the source block
    parse_block: {
        if (source.text.len == 0) break :parse_block;

        var p = parser_impl.Parser.init(allocator, source.text, "__test__.kz", &[_][]const u8{}, null) catch {
            break :parse_block;
        };
        defer p.deinit();

        var result = p.parse() catch {
            break :parse_block;
        };
        defer result.deinit();

        // Clone parsed items to owned memory
        for (result.source_file.items) |*parsed_item| {
            switch (parsed_item.*) {
                .subflow_impl => {
                    const cloned = ast_functional.cloneItem(allocator, parsed_item) catch continue;
                    cloned_mocks.append(allocator, cloned) catch {};
                },
                .flow => {
                    const cloned = ast_functional.cloneItem(allocator, parsed_item) catch continue;
                    cloned_flows.append(allocator, cloned) catch {};
                },
                else => {},
            }
        }
    }

    // Build mock lookup map
    var mock_paths = std_import.StringHashMap(ast.BranchConstructor).init(allocator);

    // First: scan program AST for constant events (SubflowImpl.body.immediate)
    const scanForConstants = struct {
        fn scan(items: []const ast.Item, paths: *std_import.StringHashMap(ast.BranchConstructor), alloc: std_import.mem.Allocator) void {
            for (items) |prog_item| {
                switch (prog_item) {
                    .subflow_impl => |sf| {
                        if (sf.body == .immediate) {
                            var path_buf = std_import.ArrayList(u8).initCapacity(alloc, 64) catch unreachable;
                            for (sf.event_path.segments, 0..) |seg, i| {
                                if (i > 0) path_buf.append(alloc, '.') catch {};
                                path_buf.appendSlice(alloc, seg) catch {};
                            }
                            paths.put(path_buf.items, sf.body.immediate) catch {};
                        }
                    },
                    .module_decl => |mod| {
                        scan(mod.items, paths, alloc);
                    },
                    else => {},
                }
            }
        }
    };
    scanForConstants.scan(program.items, &mock_paths, allocator);

    // Second: add explicit test mocks (override any module-level constants)
    for (cloned_mocks.items) |mock_item| {
        if (mock_item == .subflow_impl) {
            const sf = mock_item.subflow_impl;
            if (sf.body == .immediate) {
                var path_buf = std_import.ArrayList(u8).initCapacity(allocator, 64) catch unreachable;
                for (sf.event_path.segments, 0..) |seg, i| {
                    if (i > 0) path_buf.append(allocator, '.') catch {};
                    path_buf.appendSlice(allocator, seg) catch {};
                }
                mock_paths.put(path_buf.items, sf.body.immediate) catch {};
            }
        }
    }

    // Walk flows for purity checking
    var impure_events = std_import.ArrayList([]const u8).initCapacity(allocator, 8) catch unreachable;
    for (cloned_flows.items) |flow_item| {
        if (flow_item == .flow) {
            walkFlowForPurity(&flow_item.flow, &mock_paths, &impure_events, program.items, allocator);
        }
    }

    // Error on impure events without mocks
    if (impure_events.items.len > 0) {
        var err_msg = std_import.ArrayList(u8).initCapacity(allocator, 256) catch unreachable;
        err_msg.appendSlice(allocator, "Test '") catch {};
        err_msg.appendSlice(allocator, test_name) catch {};
        err_msg.appendSlice(allocator, "' has impure events without mocks:\n") catch {};
        for (impure_events.items) |event_path| {
            err_msg.appendSlice(allocator, "  - ") catch {};
            err_msg.appendSlice(allocator, event_path) catch {};
            err_msg.appendSlice(allocator, "\n") catch {};
        }
        @panic(err_msg.items);
    }

    // Generate test code using emitter infrastructure
    const EMIT_BUFFER_SIZE = 16 * 1024;
    const emit_buffer = allocator.alloc(u8, EMIT_BUFFER_SIZE) catch unreachable;
    var code_emitter = emitter_helpers.CodeEmitter.init(emit_buffer);

    var emit_ctx = emitter_helpers.EmissionContext{
        .allocator = allocator,
        .indent_level = 1,
        .ast_items = program.items,
        .main_module_name = "input",
        .is_sync = true,
    };
    code_emitter.indent_level = 1;

    // Emit each flow with mock substitution
    var result_counter: usize = 0;
    for (cloned_flows.items) |flow_item| {
        if (flow_item == .flow) {
            emitFlowWithMocks(&code_emitter, &emit_ctx, &flow_item.flow, &mock_paths, &result_counter) catch {};
        }
    }

    const flow_code = code_emitter.getOutput();

    // Build final test block
    const test_code = std_import.fmt.allocPrint(
        allocator,
        \\test "{s}" {{
        \\{s}}}
        ,
        .{ test_name, flow_code }
    ) catch unreachable;

    // Create inline_code item
    const new_item = ast.Item{ .inline_code = ast.InlineCode{
        .code = test_code,
        .location = flow.location,
        .module = allocator.dupe(u8, flow.module) catch unreachable,
    } };

    const maybe_new_program = ast_functional.replaceFlowRecursive(allocator, program, flow, new_item) catch unreachable;
    if (maybe_new_program) |new_program| {
        const result_program = allocator.create(ast.Program) catch unreachable;
        result_program.* = new_program;
        return .{ .transformed = .{ .program = result_program } };
    }
    return .{ .transformed = .{ .program = program } };
}

// Helper: Walk flow checking purity
const walkFlowForPurity = struct {
    fn call(
        flow_to_walk: *const @import("ast").Flow,
        mocks: *const @import("std").StringHashMap(@import("ast").BranchConstructor),
        impure_list: *@import("std").ArrayList([]const u8),
        all_items: []const @import("ast").Item,
        allocator: @import("std").mem.Allocator,
    ) void {
        const emitter_helpers = @import("emitter_helpers");

        var path_buf = @import("std").ArrayList(u8).initCapacity(allocator, 64) catch unreachable;
        if (flow_to_walk.invocation.path.module_qualifier) |mq| {
            path_buf.appendSlice(allocator, mq) catch {};
            path_buf.append(allocator, ':') catch {};
        }
        for (flow_to_walk.invocation.path.segments, 0..) |seg, i| {
            if (i > 0) path_buf.append(allocator, '.') catch {};
            path_buf.appendSlice(allocator, seg) catch {};
        }
        const inv_path = path_buf.items;

        if (mocks.get(inv_path)) |_| return;

        if (emitter_helpers.findProcDeclByPath(all_items, &flow_to_walk.invocation.path)) |proc| {
            if (!proc.is_pure) {
                for (impure_list.items) |existing| {
                    if (@import("std").mem.eql(u8, existing, inv_path)) return;
                }
                impure_list.append(allocator, inv_path) catch {};
            }
        } else if (emitter_helpers.findEventDeclByPath(all_items, &flow_to_walk.invocation.path)) |event| {
            if (!event.is_pure) {
                for (impure_list.items) |existing| {
                    if (@import("std").mem.eql(u8, existing, inv_path)) return;
                }
                impure_list.append(allocator, inv_path) catch {};
            }
        }

        for (flow_to_walk.continuations) |cont| {
            walkContinuation(&cont, mocks, impure_list, all_items, allocator);
        }
    }

    fn walkContinuation(
        cont: *const @import("ast").Continuation,
        mocks: *const @import("std").StringHashMap(@import("ast").BranchConstructor),
        impure_list: *@import("std").ArrayList([]const u8),
        all_items: []const @import("ast").Item,
        allocator: @import("std").mem.Allocator,
    ) void {
        if (cont.node) |node| {
            if (node == .invocation) {
                const temp_flow = @import("ast").Flow{
                    .invocation = node.invocation,
                    .continuations = cont.continuations,
                    .location = cont.location,
                    .module = "",
                    .is_pure = true,
                    .is_transitively_pure = false,
                };
                call(&temp_flow, mocks, impure_list, all_items, allocator);
            } else {
                for (cont.continuations) |nested| {
                    walkContinuation(&nested, mocks, impure_list, all_items, allocator);
                }
            }
        } else {
            for (cont.continuations) |nested| {
                walkContinuation(&nested, mocks, impure_list, all_items, allocator);
            }
        }
    }
}.call;

// Helper: Emit flow with mock substitution using real emitter
const emitFlowWithMocks = struct {
    fn call(
        emitter: *@import("emitter_helpers").CodeEmitter,
        ctx: *@import("emitter_helpers").EmissionContext,
        flow_to_emit: *const @import("ast").Flow,
        mocks: *const @import("std").StringHashMap(@import("ast").BranchConstructor),
        counter: *usize,
    ) !void {
        const emitter_helpers = @import("emitter_helpers");

        var path_buf = @import("std").ArrayList(u8).initCapacity(ctx.allocator, 64) catch unreachable;
        for (flow_to_emit.invocation.path.segments, 0..) |seg, i| {
            if (i > 0) try path_buf.append(ctx.allocator, '.');
            try path_buf.appendSlice(ctx.allocator, seg);
        }
        const inv_path = path_buf.items;

        if (mocks.get(inv_path)) |bc| {
            const result_var = try @import("std").fmt.allocPrint(ctx.allocator, "result_{d}", .{counter.*});
            counter.* += 1;

            try emitter.writeIndent();
            try emitter.write("const ");
            try emitter.write(result_var);
            try emitter.write(" = ");
            try emitter_helpers.emitBranchConstructor(emitter, ctx, &bc, true);
            try emitter.write(";\n");

            for (flow_to_emit.continuations) |cont| {
                if (@import("std").mem.eql(u8, cont.branch, bc.branch_name)) {
                    if (cont.binding) |binding| {
                        try emitter.writeIndent();
                        try emitter.write("const ");
                        try emitter.write(binding);
                        try emitter.write(" = ");
                        try emitter.write(result_var);
                        try emitter.write(".");
                        try emitter.write(bc.branch_name);
                        try emitter.write(";\n");
                        try emitter.writeIndent();
                        try emitter.write("_ = &");
                        try emitter.write(binding);
                        try emitter.write(";\n");
                    }
                    if (cont.node) |node| {
                        if (node == .invocation) {
                            const nested_flow = @import("ast").Flow{
                                .invocation = node.invocation,
                                .continuations = cont.continuations,
                                .location = cont.location,
                                .module = "",
                                .is_pure = true,
                                .is_transitively_pure = false,
                            };
                            try call(emitter, ctx, &nested_flow, mocks, counter);
                        }
                    }
                    break;
                }
            }

            try emitter.writeIndent();
            try emitter.write("_ = &");
            try emitter.write(result_var);
            try emitter.write(";\n");
        } else {
            try emitter_helpers.emitFlow(emitter, ctx, flow_to_emit);
        }
    }
}.call;

// Test with shared harness (mocks can be unused per-test)
~[keyword|comptime|transform] pub event test.with_harness {
    expr: Expression,
    harness: []const u8,
    source: Source
}

// Define a test harness with shared mocks
~[keyword|comptime|transform] pub event test.harness {
    expr: Expression,
    source: Source
}

// =============================================================================
// Assertions
// =============================================================================

// Simple pass - just marks the test as passed at this point
~[keyword] pub event assert.ok {}
| ok {}

~[pure] proc assert.ok {
    return .{ .ok = .{} };
}

// Simple fail - fails the test with optional message
~[keyword] pub event assert.fail { message: ?[]const u8 }
| failed {}

~[pure] proc assert.fail {
    const msg = message orelse "Assertion failed";
    @panic(msg);
}

// Equality assertion
~[keyword] pub event assert.eq { expected: Expression, actual: Expression }
| ok {}
| failed { expected: []const u8, actual: []const u8 }

// TODO: Transform to generate Zig equality check

// Contains assertion (for strings/slices)
~[keyword] pub event assert.contains { haystack: Expression, needle: Expression }
| ok {}
| failed {}

// TODO: Transform to generate Zig contains check

// =============================================================================
// Property Testing
// =============================================================================

// Test that multiple variants produce equivalent results
// Usage:
//   ~test.property.equivalent {
//       ~ast:select(blur|*)
//   }
~[comptime|transform] pub event test.property.equivalent {
    source: Source
}

