// Test shorthand property syntax in arguments and branch constructors
const std = @import("std");

~event user.create { name: []const u8, email: []const u8, age: i32 }
| success { id: i32, name: []const u8, email: []const u8 }
| failure { reason: []const u8 }

~event db.insert { table: []const u8, name: []const u8, email: []const u8, age: i32 }
| inserted { record_id: i32 }
| error { message: []const u8 }

~event notify.welcome { user_id: i32, user_email: []const u8 }

// Event that creates a user and notifies them
~event register.user { name: []const u8, email: []const u8, age: i32 }
| registered { id: i32 }
| failed { error: []const u8 }

// Implement with subflow using shorthand everywhere possible
~register.user = db.insert (table: "users", name, email, age)
| inserted i |> user.create (name, email, age)  // All shorthand!
  | success s |> notify.welcome (user_id: s.id, user_email: s.email)
    |> registered { s.id }
  | failure f |> failed { error: f.reason }
| error e |> failed { error: e.message }

// Test mixed shorthand in branch constructors
~event transform.data { value: i32, status: []const u8 }
| done { value: i32, status: []const u8, timestamp: i64 }

~transform.data = db.insert (table: "log", name: "transform", email: "none", age: value)
| inserted |> done { value, status, timestamp: 1234567890 }
| error |> done { value, status: "error", timestamp: 0 }

// Use the events
~register.user (name: "Alice", email: "alice@test.com", age: 25)
| registered r |> _ // Done
| failed f |> _ // Error

// Proc implementations  
~proc db.insert {
    if (std.mem.eql(u8, e.table, "users")) {
        return .{ .inserted = .{ .record_id = 42 } };
    }
    return .{ .inserted = .{ .record_id = 99 } };
}

~proc user.create {
    return .{ .success = .{ .id = 42, .name = e.name, .email = e.email } };
}

~proc notify.welcome {
    std.debug.print("Welcome email sent to {} at {s}\n", .{e.user_id, e.user_email});
}