~event file.read { path: []const u8 }
| success []const u8
| failure u8

~proc file.read {
    // Simulated implementation
    return .{ .@"success" = .{ .contents = "test data" } };
}

~event file.print { contents: []const u8 }
| success
| failure u8

~proc file.print {
    // Simulated implementation
    return .{ .@"success" = .{} };
}

~event proc.exit { errno: u8 }  // Void event - no branches

~proc proc.exit {
    // Void event - no return value needed
}

// Test nested continuations
~file.read (path:"input.txt")
| success s |> file.print (contents: s.contents)
  | success |> proc.exit (errno:0) |> _
  | failure e |> proc.exit (errno:e.errno) |> _
| failure f |> proc.exit (errno:f.errno) |> _