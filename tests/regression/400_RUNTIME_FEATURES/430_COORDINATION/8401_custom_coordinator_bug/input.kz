// Test: Custom Compiler Coordinator Override
//
// Validates that users can override the abstract compiler.coordinate event
// with their own pipeline implementation using ~impl.
//
// The custom coordinator prints a marker, then delegates to standard pipeline.

~import "$std/compiler"

const std = @import("std");
const ast = @import("ast");
const Program = ast.Program;

// Custom coordinator that wraps the default pipeline
// All compiler events must be module-qualified
~impl std.compiler:compiler.coordinate =
    custom_marker()
    | done |> std.compiler:compiler.context.create(program_ast: program_ast, allocator: allocator)
      | created c0 |> std.compiler:compiler.coordinate.frontend(ctx: c0.ctx)
        | continued c1 |> std.compiler:compiler.coordinate.transform_taps(ctx: c1.ctx)
          | continued c2 |> std.compiler:compiler.coordinate.analysis(ctx: c2.ctx)
            | continued c3 |> std.compiler:compiler.coordinate.test_generation(ctx: c3.ctx)
              | continued c4 |> std.compiler:compiler.coordinate.optimize(ctx: c4.ctx)
                | continued c5 |> std.compiler:compiler.coordinate.emission(ctx: c5.ctx)
                  | continued c6 |> coordinated {
                      ast: c6.ctx.ast,
                      code: c6.code,
                      metrics: "Custom coordinator ran!"
                  }
            | failed f |> error { message: f.message }

// Helper event to print marker
~event custom_marker {}
| done {}

~proc custom_marker {
    std.debug.print("CUSTOM COORDINATOR: Pipeline override active!\n", .{});
    return .{ .done = .{} };
}

// Simple test event
~pub event hello {}
| done {}

~proc hello {
    std.debug.print("Hello from custom-compiled code!\n", .{});
    return .{ .done = .{} };
}

~hello()
| done |> _
