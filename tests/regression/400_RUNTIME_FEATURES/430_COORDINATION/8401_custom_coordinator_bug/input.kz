// Test 826: Custom Coordinator Bug
//
// BUG: When user defines ~compiler.coordinate subflow with custom passes,
// the backend.zig hardcodes a call to compiler_coordinate_default,
// ignoring the user's custom coordinator.
//
// EXPECTED: User-defined coordinator should run with custom passes
// ACTUAL: Only compiler_coordinate_default runs, ignoring custom passes
//
// This test adds a custom pass that transforms the AST to prove the bug.

const std = @import("std");

// Custom compiler pass that adds a marker to prove it ran
~pub event compiler.passes.add_marker { ast: ProgramAST }
| transformed { ast: ProgramAST }

~proc compiler.passes.add_marker {
    // This pass would add a marker to the AST
    // For now, just return unchanged AST
    return .{ .transformed = .{ .ast = ast } };
}

// Custom coordinator that includes our marker pass
~compiler.coordinate =
    compiler.passes.evaluate_comptime(ast: ast)
    | evaluated ev |> compiler.check.structure(ast: ev.ast)
    | valid v |> compiler.passes.add_marker(ast: v.ast)  // <-- Custom pass!
    | transformed t |> compiler.check.phantom.semantic(ast: t.ast)
    | valid v2 |> compiler.emit.zig(ast: v2.ast)
    | emitted em |> coordinated {
        ast: v2.ast,
        code: em.code,
        metrics: "Custom coordinator ran!"
    }

// Simple test event
~pub event run_test { }

~proc run_test {
    std.debug.print("Test executed\n", .{});
}
