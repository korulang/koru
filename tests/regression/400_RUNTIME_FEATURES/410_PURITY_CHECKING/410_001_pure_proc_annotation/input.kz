// Layer 3 demonstration: ~[pure] annotation on a proc lifts the
// assume-impure default. The proc gets is_pure=true and (since it
// has no calls) is_transitively_pure=true.

const std = @import("std");

~event compute { x: i32 }
| result i32

~[pure] proc compute {
    return .{ .result = x * 2 };
}

~event main {}

~compute(x: 21)
| result _ |> _
