// Test transitive purity through flows
// Pure procs compose through flows, creating transitively pure pipelines
// The optimizer can see the ENTIRE call chain!

const std = @import("std");

// Base pure operation
~event multiply { x: i32, factor: i32 }
|> multiply(x: d1.result, factor: 2)
    |> print_number(n: d2.result)
        |> _
