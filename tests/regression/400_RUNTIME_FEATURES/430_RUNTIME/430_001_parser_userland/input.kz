// Test: User-land parser access
// Verify that $std/parser is available at runtime for dynamic parsing

~import "$std/parser"

const std = @import("std");

// We need an allocator available at runtime
var gpa = std.heap.GeneralPurposeAllocator(.{}){};
const allocator = gpa.allocator();

// The source we want to parse
const test_source = "~greet()";

// Main flow - parse and report
~parser:parse.source(source: test_source, file_name: "test.kz", allocator: allocator)
| parsed p |> {
    std.debug.print("Parser works! Got AST with {d} items\n", .{p.ast.items.len});
}
| parse_error e |> {
    std.debug.print("Parse failed: {s}\n", .{e.message});
}
