// DESIGN: Registry Scope - Basic
//
// This test captures the design for runtime event registries.
// Events must be explicitly registered to be available for runtime eval.
//
// Key concepts:
// - Named scopes: ~[registry:scope(name)]
// - Explicit allowlist: only registered events can be called
// - Glob patterns: app.users:* includes all user events
// - Scope composition: scope(other) includes another scope

~import "$std/parser"
~import "$std/runtime"
~import "$std/io"

const std = @import("std");

// Define some application events
~pub event greet { name: []const u8 }
| greeted { message: []const u8 }

~proc greet {
    const msg = std.fmt.allocPrint(std.heap.page_allocator, "Hello, {s}!", .{name}) catch "Hello!";
    return .{ .greeted = .{ .message = msg } };
}

~pub event farewell { name: []const u8 }
| done {}

~proc farewell {
    std.debug.print("Goodbye, {s}!\n", .{name});
    return .{ .done = .{} };
}

// SECRET event - should NOT be in registry
~pub event secret_admin { code: []const u8 }
| accessed {}

~proc secret_admin {
    std.debug.print("ADMIN ACCESS: {s}\n", .{code});
    return .{ .accessed = .{} };
}

// Define a registry scope - ONLY these events are available at runtime
~std.runtime:register(scope: "api") {
    greet           // Our greet event
    farewell        // Our farewell event
    std.io:print.ln // Stdlib printing
    // NOTE: secret_admin is NOT included!
}

// Sample code to eval - this should WORK
const ALLOWED_CODE =
    \\~greet(name: "World")
    \\| greeted g |> std.io:print.ln("{{g.message}}")
;

// Sample code to eval - this should FAIL (event not in registry)
const DENIED_CODE =
    \\~secret_admin(code: "hunter2")
    \\| accessed |> std.io:print.ln("Got access!")
;

// Parse and eval with scope
~std.parser:parse.source(source: ALLOWED_CODE, file_name: "allowed.kz", allocator: std.heap.page_allocator)
| parsed p |> std.runtime:eval(ast: p.ast, scope: "api")
    | result |> std.io:print.ln("Allowed code executed successfully")
    | event_denied e |> std.io:print.ln("UNEXPECTED: {{e.name}} was denied")
| parse_error e |> std.io:print.ln("Parse error: {{e.message}}")

// This should be denied
~std.parser:parse.source(source: DENIED_CODE, file_name: "denied.kz", allocator: std.heap.page_allocator)
| parsed p |> std.runtime:eval(ast: p.ast, scope: "api")
    | result |> std.io:print.ln("UNEXPECTED: Denied code executed!")
    | event_denied e |> std.io:print.ln("Correctly denied: {{e.name}}")
| parse_error e |> std.io:print.ln("Parse error: {{e.message}}")
