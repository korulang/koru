// Test: Registry Scope - Basic
//
// Verifies that ~std.runtime:register generates:
// 1. Dispatcher functions for each scope
// 2. __koru_get_scope() lookup function

~import "$std/runtime"
~import "$std/io"

const std = @import("std");

// Define some application events
~pub event greet { name: []const u8 }
| greeted { message: []const u8 }

~proc greet {
    const msg = std.fmt.allocPrint(std.heap.page_allocator, "Hello, {s}!", .{name}) catch "Hello!";
    return .{ .greeted = .{ .message = msg } };
}

~pub event farewell { name: []const u8 }
| done {}

~proc farewell {
    std.debug.print("Goodbye, {s}!\n", .{name});
    return .{ .done = .{} };
}

// Register a scope with these events
~std.runtime:register(scope: "api") {
    greet
    farewell
}

// Test: Verify the registry was generated
pub fn main() void {
    std.debug.print("\n", .{});
    std.debug.print("в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\n", .{});
    std.debug.print("в•‘     REGISTRY SCOPE BASIC TEST                                в•‘\n", .{});
    std.debug.print("в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n\n", .{});

    // Test 1: __koru_get_scope should find "api" scope
    std.debug.print("Test 1: Looking up scope 'api'...\n", .{});
    if (__koru_get_scope("api")) |dispatcher| {
        std.debug.print("  вњ“ Found dispatcher for 'api' scope\n", .{});
        _ = dispatcher;
    } else {
        std.debug.print("  вњ— FAILED: Could not find 'api' scope\n", .{});
    }

    // Test 2: __koru_get_scope should NOT find "nonexistent" scope
    std.debug.print("\nTest 2: Looking up scope 'nonexistent'...\n", .{});
    if (__koru_get_scope("nonexistent")) |_| {
        std.debug.print("  вњ— FAILED: Found unexpected scope\n", .{});
    } else {
        std.debug.print("  вњ“ Correctly returned null for nonexistent scope\n", .{});
    }

    std.debug.print("\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\n", .{});
    std.debug.print("в•‘     REGISTRY TESTS COMPLETE                                  в•‘\n", .{});
    std.debug.print("в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n", .{});
}
