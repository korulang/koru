// Test 191: Module Wildcard + Concrete Branch (INVALID - MUST FAIL)
//
// Pattern: ~input:* -> * | formatted f |>
//
// This is INVALID because:
// - Source is module wildcard (input:*) - matches all events in main module
// - Branch is concrete (formatted) - requires specific branch shape
// - Type error: Not all main module events have .formatted branch!
// - compute has .result, format has .formatted - incompatible!
//
// Expected error: "Cannot use concrete branch 'formatted' with wildcard source pattern 'input:*'"

const std = @import("std");

~import "$app/test_lib/logger"

~event compute { x: i32 }
| result { value: i32 }

~event format { value: i32 }
| formatted { text: []const u8 }

~proc compute {
    return .{ .result = .{ .value = x * 2 } };
}

~proc format {
    return .{ .formatted = .{ .text = "formatted" } };
}

~compute(x: 42)
| result r |> format(value: r.value)
    | formatted |> _
