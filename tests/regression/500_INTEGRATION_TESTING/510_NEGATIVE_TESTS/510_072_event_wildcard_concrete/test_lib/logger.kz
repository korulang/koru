// Logger for event wildcard tap test

const std = @import("std");
~import "$std/taps"

~pub event log { msg: []const u8 }
| done {}

~proc log {
    std.debug.print("[TAP] {s}\n", .{msg});
    return .{ .done = .{} };
}

// Event wildcard tap using metatype (valid usage)
~tap(*:log -> *)
| Profile p |> log(msg: p.source)
    | done |> _
