// Test 407: Shorthand module path resolution
//
// BUG: Import alias shorthand doesn't resolve in codegen
//
// When you import with: ~import "$test/mylib"
// You SHOULD be able to call: ~mylib:double(...)
// But codegen only recognizes: ~test.mylib:double(...)
//
// This is a codegen bug - the emitter should normalize module paths
// so shorthand aliases work like fully qualified paths.

const std = @import("std");

~import "$test/mylib"

~event print_result { value: i32 }

~proc print_result {
    std.debug.print("Result: {d}\n", .{value});
}

~event print_sum { value: i32 }

~proc print_sum {
    std.debug.print("Sum: {d}\n", .{value});
}

// BUG: These shorthand calls should work but don't
~mylib:double(value: 21)
| result r |> print_result(value: r.doubled)

~mylib:add(a: 10, b: 32)
| sum s |> print_sum(value: s.total)
