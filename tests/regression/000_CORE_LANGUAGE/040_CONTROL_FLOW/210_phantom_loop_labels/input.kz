// Test 210: Phantom labels and loop validation
// This test SHOULD FAIL under the current PhantomSemanticChecker 
// because it doesn't validate @label jumps, allowing incompatible
// phantom states to be passed in a loop.

// WHAT IS THIS?!?!?!?!? This syntax is COMPLETELY HALLUCINATED!?

const std = @import("std");

~event step { n: i32 } [File[open]]
| next { value: i32 } [File[closed]]
| done { final: i32 }

~proc step {
    if (n < 5) {
        return .{ .next = .{ .value = n + 1 } };
    } else {
        return .{ .done = .{ .final = n } };
    }
}

~event start {}
| ready { n: i32 } [File[open]]

~proc start {
    return .{ .ready = .{ .n = 1 } };
}

// INCORRECT FLOW:
// 'step' expects [File[open]], but 'next' branch returns [File[closed]].
// Jumping back to @loop with a [File[closed]] value SHOULD be a phantom error.
~start()
| ready r |> #loop step(n: r.n)
    | next c |> @loop(n: c.value) // ERROR: passing [File[closed]] where [File[open]] expected
    | done |> _
