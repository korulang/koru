// Test: Void pipeline sequence - multiple steps after void events
// This tests that |> chains work correctly after void events like print.ln

~import "$std/io"

// Simple work event
~event work {}
| done

~proc work {
    return .{ .done = .{} };
}

~work()
| done |> std.io:print.ln("Step 1") |> work() |> std.io:print.ln("Step 2")
    | done |> std.io:print.ln("Done!")
