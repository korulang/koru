// Test: Void pipeline sequence - multiple steps after void events
// This tests that |> chains work correctly after void events like print.ln

~import "$std/io"

// Simple work event
~event work {}

~proc work {
}

~work()
|> std.io:print.ln("Step 1") |> work() |> std.io:print.ln("Step 2")
    |> std.io:print.ln("Done!")
