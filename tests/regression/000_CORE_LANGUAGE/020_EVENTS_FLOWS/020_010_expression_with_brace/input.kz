// Test: Expression parameter starting with brace
// Verifies parser captures { ... } as Expression argument

~event test_expr { val: Expression }

~proc test_expr {
    const std = @import("std");
    std.debug.print("val={s}\n", .{val});
}

// This should parse { foo: 1 } as the Expression argument
// Using explicit val: to avoid implicit argument issues
~test_expr(val: { foo: 1 })
|> _
