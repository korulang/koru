// Tour 01: Branches and Control Flow with I/O
// This demonstrates event branches and importing

// Import I/O for printing
~import "../../koru_std/io"

// Import std for this module (each module needs its own)
const std = @import("std");

// Event that processes a greeting request
~event process_greeting { name: []const u8 }
| friendly []const u8
| formal []const u8
| unknown

// Proc that decides how to greet based on the name
~proc process_greeting {
    // Check the name and return different branches
    if (std.mem.eql(u8, e.name, "friend")) {
        return .{ .friendly = .{ .msg = "Hey buddy! 👋" }};
    } else if (std.mem.eql(u8, e.name, "boss")) {
        return .{ .formal = .{ .msg = "Good day, sir/madam." }};
    } else if (e.name.len == 0) {
        return .{ .unknown = .{} };
    } else {
        // Generic friendly greeting for everyone else
        return .{ .friendly = .{ .msg = "Hello there!" }};
    }
}

// Main flow - demonstrate different branches
~process_greeting(name: "friend")
| friendly f |> io.println(text: f.msg)
| formal f |> io.println(text: f.msg)
| unknown |> io.println(text: "Who are you?")
