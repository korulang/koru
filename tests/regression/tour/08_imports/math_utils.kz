// Tour 08: Math Utilities Module
// This module provides math-related events that can be imported by other files

const std = @import("std");

// Public event - will be available when imported
~pub event add { a: i32, b: i32 }
| sum i32

// Another public event
~pub event multiply { x: i32, y: i32 }
| product i32

// Public event with multiple branches
~pub event divide { numerator: f64, denominator: f64 }
| success f64
| error []const u8

// Private event - NOT available when imported (no 'pub')
~event internal_helper { value: i32 }
| processed i32

// Implementations (procs are always private)
~proc add {
    return .{ .sum = e.a + e.b };
}

~proc multiply {
    return .{ .product = e.x * e.y };
}

~proc divide {
    if (e.denominator == 0) {
        return .{ .error = "Division by zero" };
    }
    return .{ .success = e.numerator / e.denominator };
}

~proc internal_helper {
    // This is only usable within this file
    return .{ .processed = e.value * 2 };
}

// Note: When another file imports this module, they will get:
// - math_utils.add (or custom_name.add if they rename it)
// - math_utils.multiply
// - math_utils.divide
// But NOT:
// - internal_helper (not public)
// - Any of the procs (procs are never exported)