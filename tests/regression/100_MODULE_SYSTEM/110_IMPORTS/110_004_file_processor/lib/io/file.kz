// File I/O module

const std = @import("std");

~pub event read { path: []const u8 }
| success []const u8
| notfound
| ioerror []const u8

~pub event write { path: []const u8, data: []const u8 }
| written
| ioerror []const u8

~proc read {
    // Stub implementation for test
    return .{ .@"notfound" = .{} };
}

~proc write {
    // Stub implementation for test
    return .{ .@"ioerror" = .{ .msg = "write not implemented" } };
}
