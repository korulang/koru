// File I/O module

const std = @import("std");

~event read { path: []const u8 }
| success { contents: []const u8 }
| notfound {}
| ioerror { msg: []const u8 }

~event write { path: []const u8, data: []const u8 }
| written {}
| ioerror { msg: []const u8 }

~proc read {
    // Stub implementation for test
    return .{ .@"notfound" = .{} };
}

~proc write {
    // Stub implementation for test
    return .{ .@"ioerror" = .{ .msg = "write not implemented" } };
}
