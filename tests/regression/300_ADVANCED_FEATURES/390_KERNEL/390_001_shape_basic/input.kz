// TEST: kernel.shape and kernel.init basic usage
//
// kernel.shape is [norun] - just declares structure, sits in AST
// kernel.init is [transform] - creates struct + instance, replaces flow

const std = @import("std");

~import "$std/kernel"

// Declare the shape (explicit types) - this is [norun], just metadata
~std.kernel:shape(Body) {
    x: f64,
    y: f64,
    mass: f64,
}

// Initialize kernel data - this is a transform
~std.kernel:init(Body) {
    x: 42.0,
    y: 0,
    mass: 1.5,
}

// Access the generated variable (default name is kernel_data)
pub fn main() void {
    std.debug.print("x={d}, mass={d}\n", .{ kernel_data.x, kernel_data.mass });
}
