~import "$std/kernel"
~import "$std/io"

~std.kernel:shape(Body) {
    mass: f64,
}

~std.kernel:init(Body) {
    { mass: 1.0 },
    { mass: 2.0 },
}
| kernel k |>
    std.kernel:pairwise {
        k.mass += k.other.mass
    }
| computed c |>
    std.io:print.blk {
        done, mass[0]={{ c[0].mass:f }}
    }
