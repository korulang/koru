~import "$std/testing"

~event do_thing {}

// Test that passes - assert true
~test(This test passes) {
    ~do_thing = done {}
    ~do_thing() |> assert(true)
}

// Test that fails deliberately - assert false
~test(This test should fail) {
    ~do_thing = done {}
    ~do_thing() |> assert(false)
}

pub fn main() void {}
