// Test: Basic test transform
//
// Tests the test transform generates a Zig test block.
// The transform currently generates a stub - full mock support comes later.

~import "$std/testing"

// Event to be mocked in tests
~event get_balance {}
| amount { value: u32 }

// Basic test with mock and assertion
~test(User balance is mocked correctly) {
    ~get_balance = amount { value: 100 }
    ~get_balance()
    | amount a |> assert.ok()
}

pub fn main() void {}
