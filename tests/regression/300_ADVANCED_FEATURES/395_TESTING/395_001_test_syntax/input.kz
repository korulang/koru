// Test: Full aspirational test syntax
//
// This test documents the DESIRED syntax for the testing framework.
// It should fail until we fix:
// 1. Expression + Source parameter codegen
// 2. Mock detection and mangling
// 3. Purity tracing integration

~import "$std/testing"

// Aspirational syntax: bare Expression for test name
~test(User cannot withdraw more than balance) {
    // Mock: account has 50
    ~account.balance = amount 50

    // Test: try to withdraw 100
    ~app:withdraw(amount: 100)
    | insufficient_funds |> assert.ok()
    | success |> assert.fail(message: "Should have failed")
}

// With category
~test(Transaction rejected on empty account, category: "Payments") {
    ~account.balance = amount 0
    ~payment.gateway = declined { reason: "Insufficient funds" }

    ~app:charge(amount: 100)
    | failure f |> assert.ok()
    | success |> assert.fail(message: "Should have been rejected")
}

// Property testing: all blur variants must be equivalent
~test.property.equivalent {
    ~ast:select(blur|*)
}

pub fn main() void {}
