// Test: Cross-module mocking
//
// This test captures the requirement for mocking events from IMPORTED modules.
// Currently this should FAIL because cross-module mock support is not implemented.
//
// The syntax `~std.fs:read_lines = lines { ... }` means:
// "For this test, provide this implementation for the std.fs:read_lines event"
//
// This is NOT just for testing - Source blocks with impl declarations enable:
// - Compile-time code synthesis
// - AI-generated implementations
// - Remote code fetching
// - Interactive compilation
//
// The compiler becomes a development partner, not just a batch processor.

~import "$std/testing"
~import "$std/fs"

// A flow that depends on an external module event
~event process_config { path: []const u8 }
| ok { line_count: usize }
| failed { reason: []const u8 }

~process_config = std.fs:read_lines(path: path)
| lines l |> ok { line_count: l.len }
| failed msg |> failed { reason: msg }

// ============================================
// THE TEST - Cross-module mock
// ============================================

~test(Cross-module mock should return 3 lines) {
    // Mock the external module's event
    // Syntax: ~<module.path>:<event> = <branch> { <fields> }
    //
    // FEATURE GAPS CAPTURED BY THIS TEST:
    //
    // 1. CROSS-MODULE MOCKING: The mock should override std.fs:read_lines
    //    ACTUAL: Calls the real koru_std.fs.read_lines_event (mock not applied)
    //
    // 2. ARRAY LITERAL SYNTAX: Koru needs native array literals like ["a", "b"]
    //    ACTUAL: Parser doesn't support this, would need &.{} Zig escape hatch
    //
    // When both features are implemented:
    // - Array syntax ["line1", "line2", "line3"] should parse correctly
    // - Mock should be injected into test module
    // - process_config should return ok with line_count=3
    //
    ~std.fs:read_lines = lines ["line1", "line2", "line3"]

    ~process_config(path: "/this/file/does/not/exist.txt")
    | ok result |> assert(result.line_count == 3)
    | failed |> assert.ok()
}
