// Test: ~if compiles to literal if/else with ZERO event overhead
//
// This test verifies that the ~if transform generates INLINE Zig code
// using the Flow.inline_body field, instead of calling if_impl_event.handler.
//
// What this tests:
// - Template metaprogramming: template_utils.lookupTemplate + interpolate
// - Flow.inline_body field for zero-overhead code emission
// - continuation_codegen generates correct handler calls
// - Emitter outputs inline_body directly

~import "$std/io"

const std = @import("std");

const value = 42;

~if(value > 10)
| then |> std.io:println(text: "Greater than 10")
| else |> std.io:println(text: "10 or less")
