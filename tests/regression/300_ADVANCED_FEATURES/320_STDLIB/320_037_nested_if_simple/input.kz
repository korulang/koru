// Simplest nested if test - no print.ln, just nested if's

~import "$std/control"

const std = @import("std");

~event start {}

~proc start {
}

// Outer if contains inner if
// Both should transform to Zig if statements
~start() |> if(true)
| then |> if(false)
    | then |> _
    | else |> _
| else |> _
