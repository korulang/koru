pub const Handle = struct {
    id: i32,
};
~event open {}
| ok *Handle[open!]
~proc open {
    const h = std.heap.page_allocator.create(Handle) catch unreachable;
    h.* = .{ .id = 42 };
    return .{ .ok = h };
}
~event close { h: *Handle[!open] }
| closed
| error []const u8
~proc close {
    std.heap.page_allocator.destroy(h);
    return .{ .closed = .{} };
}
const std = @import("std");
~open()
|> _
