// TEST: Manual disposal at | done |> is allowed
// STATUS: IMPLEMENTED
//
// Test manual close in done branch - runs once after loop completes

~import "$std/control"
~import "$app/fs"

~app.fs:open(path: "outer.txt")
| opened f |>
    std.control:for(0..3)
    | each _ |> _
    | done |>
        app.fs:close(file: f.file)
        | closed _ |> _

pub fn main() void {}
