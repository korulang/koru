~import "$app/fs"
const std = @import("std");
~event iterate { count: i32 }
| next i32
~proc iterate {
    if (count < 3) {
        return .{ .next = count + 1 };
    } else {
    }
}
~#loop iterate(count: 0)
| next n |>
    app.fs:open(path: "test.txt")
    | opened f |> @loop(count: n.count)  // Auto-close f before @loop
|> _
pub fn main() void {}
