const std = @import("std");
~import "$app/test_lib/logger"
~event compute { x: i32 }
| result i32
~event format { value: i32 }
| formatted []const u8
~proc compute {
    std.debug.print("compute({d})\n", .{x});
    return .{ .result = x * 2 };
}
~proc format {
    std.debug.print("format({d})\n", .{value});
    return .{ .formatted = "formatted" };
}
~compute(x: 42)
| result r |> format(value: r)
    | formatted |> _
