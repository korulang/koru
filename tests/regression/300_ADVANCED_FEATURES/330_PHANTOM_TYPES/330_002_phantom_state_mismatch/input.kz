~import "$app/lib/fs"
~import "$app/lib/mipmap"
const std = @import("std");
const File = struct {
    handle: i32,
};
~event needs_fs_file { file: *File[app.lib.fs:open] }
| processed
~proc needs_fs_file {
    return .{ .processed = .{} };
}
~app.lib.mipmap:load(path: "texture.png")
| loaded m |> needs_fs_file(file: m.file)
    | processed |> _
