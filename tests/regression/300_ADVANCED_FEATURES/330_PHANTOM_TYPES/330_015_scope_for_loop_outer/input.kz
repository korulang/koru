// TEST: Scope - obligation OUTSIDE for-loop should NOT auto-dispose inside
// STATUS: IMPLEMENTED
// MUST_FAIL: KORU032 - Cannot auto-dispose outer-scope resource inside loop
//
// When an obligation is created OUTSIDE a for-loop, the checker must NOT
// auto-dispose it inside the loop. The user must explicitly handle the
// resource outside the loop structure.
//
// Here: We open a file BEFORE the loop, then terminate inside the loop.
// This is an error - auto-dispose cannot handle outer-scope obligations.
//
// Expected: KORU032 error about outer-scope resource

~import "$std/control"
~import "$app/fs"

~app.fs:open(path: "outer.txt")
| opened outer_f |>
    std.control:for(0..3)
    | each _ |> _  // ERROR: outer_f has [opened!] but we can't dispose here
    | done |> _

pub fn main() void {}
