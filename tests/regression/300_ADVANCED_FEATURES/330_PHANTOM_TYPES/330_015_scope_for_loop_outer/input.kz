// TEST: Scope - obligation OUTSIDE for-loop is auto-disposed in done branch
// STATUS: IMPLEMENTED
//
// When an obligation is created OUTSIDE a for-loop:
// - It CANNOT be auto-disposed inside the `each` branch (@scope)
// - It CAN be auto-disposed in the `done` branch (no @scope)
//
// Here: We open a file BEFORE the loop, loop runs, then auto_dispose
// inserts close in the `done` branch. This is valid code.
//
// Expected: Compiles successfully - file is auto-closed after loop

~import "$std/control"
~import "$app/fs"

~app.fs:open(path: "outer.txt")
| opened outer_f |>
    std.control:for(0..3)
    | each _ |> _  // outer_f is suspended here (@scope), disposed in done
    | done |> _

pub fn main() void {}
