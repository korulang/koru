~import "$std/control"
~import "$app/db"
const query_succeeded = true;
~app.db:connect(url: "postgres://localhost/test")
| connected c |>
    app.db:query(conn: c, sql: "SELECT * FROM users")
    | started tx |>
        std.control:if(query_succeeded)
        | then |>
            app.db:commit(tx: tx)
            | committed |>
                app.db:disconnect(conn: c)
                | disconnected |> _
        | else |>
            app.db:rollback(tx: tx)
            | rolledback |>
                app.db:disconnect(conn: c)
                | disconnected |> _
pub fn main() void {}
