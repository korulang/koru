// Test meta-events: koru:start and koru:end
// This test verifies that meta-events fire correctly and can be tapped

const std = @import("std");

~[profile]import "$std/profiler"

~event hello {}
| done {}

~proc hello {
    std.debug.print("Hello from meta-event test!\n", .{});
    return .{ .done = .{} };
}

~hello()
| done |> _
