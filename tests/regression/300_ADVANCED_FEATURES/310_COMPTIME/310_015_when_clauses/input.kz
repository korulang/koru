// Test when clauses - conditional tap execution
const std = @import("std");
~import "$std/taps"

~event process { value: usize }
|> alert(result: d)
    |> _

// Test with low value (should not trigger alert)
~process(value: 10)
|> _

// Test with high value (should trigger alert)
~process(value: 30)
|> _