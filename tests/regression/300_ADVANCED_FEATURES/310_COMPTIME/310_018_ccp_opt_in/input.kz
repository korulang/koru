// Test 612: CCP Opt-In via Import
// Demonstrates that importing $std/ccp_taps enables JSON observability

~import "$std/ccp"

const std = @import("std");

~event greet { name: []const u8 }
| greeting []const u8

~proc greet {
    std.debug.print("Hello, {s}!\n", .{name});
    return .{ .greeting = "Hello!" };
}

~greet(name: "Koru")
| greeting _ |> _
