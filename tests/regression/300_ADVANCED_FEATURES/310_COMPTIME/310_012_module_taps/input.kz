const std = @import("std");

// TODO: This would import a module with events
~import "$test/events"

~event main_event {}
| done {}

~pub event observer {}
| done {}

~proc main_event {
    std.debug.print("Main event executed\n", .{});
    return .{ .done = .{} };
}

~proc observer {
    std.debug.print("Observer fired!\n", .{});
    return .{ .done = .{} };
}

