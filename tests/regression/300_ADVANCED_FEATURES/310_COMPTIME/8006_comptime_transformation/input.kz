// Test 806: AST Transformation - Comptime Flow Removal
// This test verifies that flows invoking comptime events are REMOVED from the final AST

const std = @import("std");

// Comptime event - this executes at compile-time
~event analyze_ast { ast: ProgramAST }
| analyzed { count: usize }

~proc analyze_ast {
    var count: usize = 0;
    for (ast.items) |item| {
        if (item == .event_decl) {
            count += 1;
        }
    }
    // Can't use std.debug.print at comptime
    // std.debug.print("COMPTIME: Found {} events in AST\n", .{count});
    return .{ .analyzed = .{ .count = count } };
}

// Regular runtime event - this appears in final code
~event greet { name: []const u8 }
| greeting { msg: []const u8 }

~proc greet {
    std.debug.print("Hello, {s}!\n", .{name});
    return .{ .greeting = .{ .msg = "Hello!" } };
}

// THIS FLOW INVOKES A COMPTIME EVENT - IT SHOULD BE REMOVED!
// The handler executes at compile-time, but the flow itself disappears
~analyze_ast
| analyzed |> greet(name: "World") | greeting |> _

// THIS FLOW IS REGULAR - IT SHOULD REMAIN!
~greet(name: "Koru")
| greeting |> _