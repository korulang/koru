// Test 805: First Working Comptime Execution
// This test has a comptime event that ACTUALLY EXECUTES at compile-time!

const std = @import("std");

// Comptime event that counts events in the AST
~event count_events { ast: ProgramAST }
| counted { num: usize }

~proc count_events {
    // Actually count events in the AST!
    var count: usize = 0;
    for (ast.items) |item| {
        if (item == .event_decl) {
            count += 1;
        }
    }

    std.debug.print("COMPTIME HANDLER EXECUTED! Found {} events\n", .{count});
    return .{ .counted = .{ .num = count } };
}

// Regular event for testing
~event report { num: usize }
| done {}

~proc report {
    std.debug.print("Report: {} events in AST\n", .{num});
    return .{ .done = .{} };
}

// Regular flow that demonstrates system works
~report(num: 3)
| done |> _

