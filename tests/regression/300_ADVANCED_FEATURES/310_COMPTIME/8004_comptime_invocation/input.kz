// Test 804: Comptime Event Invocation Detection
// Verifies that flows invoking comptime events are detected and handled
// For now, we're testing DETECTION, not execution (that's Phase 2, test 805)

const std = @import("std");

// Comptime event that inspects the ProgramAST
~event count_events { ast: ProgramAST }
| counted { num: usize }

~proc count_events {
    // Stub - not actually executed yet
    // Phase 2 will implement actual execution
    return .{ .counted = .{ .num = 42 } };
}

// Regular event for testing
~event finish { num: usize }
| done {}

~proc finish {
    std.debug.print("Event count: {}\n", .{num});
    return .{ .done = .{} };
}

// Regular flow that CAN be emitted (doesn't use comptime events)
~finish(num: 5)
| done |> _

