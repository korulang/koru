// Test 809: Import System Validation
// This test uses comptime events to validate import resolution

const std = @import("std");

// Import with $std alias - this should resolve correctly
~import "$std/io"

// Comptime event to validate imports in the AST
~event validate_imports { ast: ProgramAST }
| validated { import_count: usize, has_io: bool }
| validation_failed { reason: []const u8 }

~proc validate_imports {
    var import_count: usize = 0;
    var has_io_import = false;

    // Iterate through AST items looking for imports
    for (ast.items) |item| {
        if (item == .import_decl) {
            import_count += 1;
            const import_decl = item.import_decl;

            // Check if this is the io import
            // After alias resolution, path should still be stored
            // (resolution happens in module_resolver, not parser)
            if (std.mem.indexOf(u8, import_decl.path, "io") != null) {
                has_io_import = true;
            }
        }
    }

    // Validate expectations
    if (import_count == 0) {
        return .{ .validation_failed = .{ .reason = "No imports found in AST" } };
    }

    if (!has_io_import) {
        return .{ .validation_failed = .{ .reason = "io import not found" } };
    }

    return .{ .validated = .{
        .import_count = import_count,
        .has_io = has_io_import
    } };
}

// Regular runtime event that uses the imported module
~event test_import {}
| tested { result: []const u8 }

~proc test_import {
    std.debug.print("Testing import resolution\n", .{});
    return .{ .tested = .{ .result = "Import works" } };
}

// Comptime flow - validates AST structure
~validate_imports
| validated |> test_import | tested |> _
| validation_failed |> _

// Runtime flow - uses the imported io module
~io:println(text: "Import alias resolved!")
