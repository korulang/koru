// Test annotations - profiling adds timing data
const std = @import("std");

~event work {}
| done {}

~event profiler { duration_ns: u64 }
| done {}

~proc work {
    std.debug.print("Work executed\n", .{});
    return .{ .done = .{} };
}

~proc profiler {
    // With [profiling] annotation, t.duration_ns should be available
    std.debug.print("Duration: {} ns\n", .{duration_ns});
    return .{ .done = .{} };
}

// Tap with profiling annotation - should add timing instrumentation
~[profiling]work -> *
| Transition t |> profiler(duration_ns: t.duration_ns.?)
    | done |> _

~work()
| done |> _