// Test 655: Command declarations with subcommands
//
// command.declare should support subcommands so that complex CLI tools
// can be expressed. For example, `deps` has subcommands like `install`.
//
// The help output should show:
//   deps                 Check and install system dependencies
//     deps install       Install missing dependencies
//     deps check         Check dependency status (default)
//
// Or alternatively:
//   deps [install|check] Check and install system dependencies
//
// Run: koruc input.kz --help
// Expected: Help shows "deps" with indication of subcommands

~import "$std/deps"

~event main {}
| done {}

~proc main {
    return .{ .done = .{} };
}

~main()
| done |> _
