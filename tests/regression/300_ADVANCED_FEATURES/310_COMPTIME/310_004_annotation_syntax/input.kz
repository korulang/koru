// Test 011: New annotation syntax ~[annotation]construct
// Tests:
// - [raw] annotation preventing inline flow extraction  
// - Multiple annotations with |
// - Annotations on events and procs

const std = @import("std");

~import "$std/io"

// Helper event for testing inline flows
~event compute { val: i32 }
| success { result: i32 }
| failure { code: i32 }

~proc compute {
    if (val > 0) {
        return .{ .success = .{ .result = val * 2 } };
    }
    return .{ .failure = .{ .code = 1 } };
}

// Normal proc - inline flows should be extracted
~event test_normal { x: i32 }
| done { value: i32 }

~test_normal = compute(val: x)
    | success s |> done { value: s.result }
    | failure f |> done { value: -1 };
    
// Raw proc - inline flows should NOT be extracted
~event test_raw { x: i32 }
| done { value: i32 }

~[raw]proc test_raw = compute(val: x)
    | success s |> done { value: s.result }
    | failure f |> done { value: -1 };

// Multiple annotations test
~event test_multi { x: i32 }
| done { value: i32 }

~[inline|pure]proc test_multi {
    return .{ .done = .{ .value = x * 3 } };
}

// Annotated public event
~[fusible]pub event public_test { n: i32 }
| result { value: i32 }

~proc public_test {
    return .{ .result = .{ .value = n + 1 } };
}

// Test verification event
~event verify_test {}
| done {}

~proc verify_test {
    // Test 1: Normal proc should have inline flows extracted
    // Call test_normal and verify it works
    const normal_result = test_normal_event.handler(.{ .x = 5 });
    switch (normal_result) {
        .done => |d| {
            // Should be 5 * 2 = 10 from compute
            if (d.value == 10) {
                std.debug.print("Normal proc works: {}\n", .{d.value});
            } else {
                std.debug.print("FAILED normal: expected 10, got {}\n", .{d.value});
            }
        },
    }

    // Test 2: Raw proc preserves Koru syntax
    // Since [raw] preserves the syntax, this test would fail to compile
    // if raw annotation wasn't working (the Koru syntax would be invalid Zig)
    // So if we get here, [raw] is working
    std.debug.print("[raw] annotation preserves syntax\n", .{});

    // Test 3: Multiple annotations accepted
    const multi_result = test_multi_event.handler(.{ .x = 7 });
    switch (multi_result) {
        .done => |d| {
            // Should be 7 * 3 = 21
            if (d.value == 21) {
                std.debug.print("Multiple annotations work: {}\n", .{d.value});
            } else {
                std.debug.print("FAILED multi: expected 21, got {}\n", .{d.value});
            }
        },
    }

    return .{ .done = .{} };
}

~verify_test()
| done |> _