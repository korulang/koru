// Test 803: Comptime Event Detection
// Verifies that the evaluate_comptime pass detects events with FlowAST/ProgramAST/Source parameters

const std = @import("std");

// Regular event - should NOT be detected as comptime-only
~event greet { name: []const u8 }
| greeting { message: []const u8 }

~proc greet {
    return .{ .greeting = .{ .message = "Hello!" } };
}

// Comptime event with FlowAST - SHOULD be detected
~event analyze_flow { flow: FlowAST }
| analyzed { count: usize }

~proc analyze_flow {
    // Stub - not actually executed yet
    return .{ .analyzed = .{ .count = 0 } };
}

// Comptime event with ProgramAST - SHOULD be detected
~event analyze_program { ast: ProgramAST }
| analyzed { events: usize }

~proc analyze_program {
    // Stub - not actually executed yet
    return .{ .analyzed = .{ .events = 0 } };
}

// Comptime event with Source - SHOULD be detected
~event parse_sql { sql: Source }
| parsed { rows: usize }

~proc parse_sql {
    // Stub - not actually executed yet
    return .{ .parsed = .{ .rows = 0 } };
}

// Simple flow - just needs to compile
~greet(name: "Koru")
| greeting |> _