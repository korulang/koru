// Test 310_041: Named Expression Parameters in Transforms
//
// BUG: The parser always expects a single implicit `expr: Expression` parameter.
// It doesn't recognize that multiple named parameters can each be Expression types.
//
// Current working syntax:
//   ~tap(hello -> *)              <- single implicit expression
//
// Desired syntax that should ALSO work:
//   ~tap(source: hello, dest: *)  <- named expression parameters
//
// This test validates that named Expression parameters work correctly.

const std = @import("std");
~import "$std/taps_named"

// An event with a branch that can be tapped
// NOTE: Taps work by observing TRANSITIONS (branches), not void events!
// The branch is named 'tap_target' to make clear this is TEST SCAFFOLDING.
~event hello {}
| tap_target {}

~proc hello {
    std.debug.print("Hello executed\n", .{});
    return .{ .tap_target = .{} };
}

// A void observer event
~event observer {}

~proc observer {
    std.debug.print("Observer fired!\n", .{});
}

// TAP using named expression parameters (currently broken)
~tap_named(source: hello, dest: *)
| tap_target |> observer()

// Execute hello - tap should fire on tap_target branch
~hello()
| tap_target |> _
