// Test 055: Source Parameter Syntax
// Tests that Source type is recognized and marked in AST

const std = @import("std");

// Event with Source parameter (for macros/code generation)
~event compile { code: Source }
| compiled { result: []const u8 }

~event macro_expand { template: Source }
| expanded { code: []const u8 }

// Proc implementations
~proc compile {
    // Placeholder - actual code compilation would go here
    return .{ .compiled = .{ .result = "" } };
}

~proc macro_expand {
    // Placeholder - actual macro expansion would go here
    return .{ .expanded = .{ .code = "" } };
}
