~import "$std/io"

// Runtime event that provides user data
~event getUserData { }
| data { name: []const u8, age: i32 }

~proc getUserData {
    return .{ .data = .{ .name = "Alice", .age = 42 } };
}

// Comptime event that does template expansion
// This receives the captured scope and generates runtime code
~event renderHTML {
    source: Source[HTML],
    item: *const Item,
    program_ast: *const ProgramAST,
    allocator: std.mem.Allocator
}
| transformed { item: Item }

~proc renderHTML {
    // THE MAGIC HAPPENS HERE!
    //
    // 1. Parse source.text for ${...} interpolations
    //    Example: "<h1>${u.name}</h1>" finds "${u.name}"
    //
    // 2. Look up variables in source.scope.bindings
    //    Example: bindings contains { name: "u", type: "{name: []const u8, age: i32}", value_ref: "u" }
    //
    // 3. Generate runtime Zig code that builds the HTML
    //    Example: std.fmt.allocPrint(allocator, "<h1>{s}</h1><p>Age: {d}</p>", .{u.name, u.age})
    //
    // 4. Transform the Item to contain the generated code
    //    Replace the renderHTML invocation with a new flow that:
    //    - Calls the generated formatting code
    //    - Returns the HTML string in the | rendered branch
    //
    // MVP Implementation:
    // For now, return hardcoded HTML to prove the plumbing works
    // Real interpolation will be implemented in Phase 3

    // TODO: Actual implementation will:
    // const html_code = try generateHTMLFormatter(allocator, source);
    // const transformed_flow = try createFlowWithFormattedHTML(allocator, item, html_code);
    // return .{ .transformed = .{ .item = .{ .flow = transformed_flow } } };

    // For MVP: Just return item unchanged, but document what SHOULD happen
    return .{ .transformed = .{ .item = item } };
}

// THE TEST: Continuation pipeline with scope capture
// The 'u' binding should be captured in source.scope.bindings
// renderHTML should generate code that uses u.name and u.age
~getUserData
| data u |> renderHTML [HTML]{
    <h1>${u.name}</h1>
    <p>Age: ${u.age}</p>
} | rendered h |> std.io:println(text: h.html)

// When this works, output should be:
// <h1>Alice</h1>
// <p>Age: 42</p>
