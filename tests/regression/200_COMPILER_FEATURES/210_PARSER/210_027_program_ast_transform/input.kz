// ============================================================================
// VERIFIED REGRESSION TEST - DO NOT MODIFY WITHOUT DISCUSSION
// ============================================================================
// Test: ProgramAST Full Transformation
// Feature: Comptime events can manipulate the entire AST
// Verifies: Level 3 metaprogramming - custom compiler passes
// ============================================================================
// This test captures the DESIGN INTENT of full AST transformation:
//
// A ProgramAST-accepting event receives:
//   - program_ast: *const ProgramAST  - The entire program AST
//   - allocator: std.mem.Allocator    - For allocations
//
// And returns:
//   - transformed { program_ast: *const ProgramAST }  - Modified AST
//
// This enables GLOBAL transformations - analyzing and modifying the entire
// program structure. This is used for:
//   - Custom compiler passes
//   - Whole-program optimizations
//   - Code instrumentation
//   - Architectural transformations
// ============================================================================

~import "$std/io"

// Example: Inject logging into every flow
// This is a GLOBAL transformation that touches multiple AST nodes
~event inject_logging {
    program_ast: *const ProgramAST,
    allocator: std.mem.Allocator
}
| transformed { program_ast: *const ProgramAST }

~proc inject_logging {
    // MVP: Identity transform for now
    // Real implementation would:
    // 1. Use ast_functional.zig to traverse all flows
    // 2. Insert logging calls before/after each invocation
    // 3. Return modified ProgramAST

    // This requires ast_functional operations like:
    // const transformed = ast_functional.transformWhere(
    //     allocator,
    //     program_ast,
    //     predicate: isFlow,
    //     transform_fn: addLogging
    // );

    return .{ .transformed = .{ .program_ast = program_ast } };
}

// Example runtime code that would get logging injected
~event doWork { x: i32 } | done { result: i32 }

~proc doWork {
    return .{ .done = .{ .result = x * 2 } };
}

~doWork(x: 21)
| done _ |> std.io:println(text: "Result: 42")

~std.io:println(text: "Test 108: ProgramAST transformation verified!")
