// ============================================================================
// VERIFIED REGRESSION TEST - DO NOT MODIFY WITHOUT DISCUSSION
// ============================================================================
// Test: depends_on Ordering for Comptime Events
// Feature: Comptime events can declare dependencies using ~[depends_on(...)]
// Verifies: Topological ordering of comptime transformations
// ============================================================================
// This test captures the DESIGN INTENT of comptime event ordering:
//
// Comptime events execute during evaluate_comptime pass in dependency order.
// Dependencies are declared using the ~[depends_on("qualified:name")] annotation.
//
// The system:
// 1. Builds dependency graph from annotations
// 2. Performs topological sort
// 3. Executes comptime events in order
//
// This enables composable transformations where one transform can build on another.
// ============================================================================

~import "$std/io"

// First pass: Validates and normalizes Source content
~event first_pass {
    source: Source[Stage1],
    item: *const Item,
    program_ast: *const ProgramAST,
    allocator: std.mem.Allocator
}
| transformed { item: Item }

~proc first_pass {
    // MVP: Identity transform, but in real implementation:
    // - Validate source.text syntax
    // - Normalize whitespace
    // - Add metadata to item

    return .{ .transformed = .{ .item = item } };
}

// Second pass: Depends on first_pass completing
// Uses fully qualified name: "input:first_pass"
~[depends_on("input:first_pass")]
~event second_pass {
    source: Source[Stage2],
    item: *const Item,
    program_ast: *const ProgramAST,
    allocator: std.mem.Allocator
}
| transformed { item: Item }

~proc second_pass {
    // MVP: Identity transform, but in real implementation:
    // - Assume first_pass has validated source
    // - Generate optimized code based on normalized input
    // - Transform item with confidence

    return .{ .transformed = .{ .item = item } };
}

// Test invocations
// These should execute in order: first_pass, then second_pass
~first_pass [Stage1]{
    Raw input that needs validation
}

~second_pass [Stage2]{
    Input that assumes first_pass normalization
}

~std.io:println(text: "Test 107: depends_on ordering verified!")
