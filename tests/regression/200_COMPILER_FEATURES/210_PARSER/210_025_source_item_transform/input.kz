// ============================================================================
// VERIFIED REGRESSION TEST - DO NOT MODIFY WITHOUT DISCUSSION
// ============================================================================
// Test: Source Parameter with Item Transformation
// Feature: Source events can receive and transform their AST node
// Verifies: New metaprogramming API - bounded node transformation
// ============================================================================
// This test captures the DESIGN INTENT of the new metaprogramming system:
//
// A Source-accepting event receives:
//   - source: Source[Type]        - The captured text + scope bindings
//   - item: *const Item           - The AST node containing this invocation
//   - program_ast: *const Program - Full AST for context (read-only)
//   - allocator: std.mem.Allocator   - For allocation
//
// And returns:
//   - transformed { item: Item }  - The replacement AST node
//
// This enables BOUNDED transformations - each comptime event transforms
// only its own node, making transformations composable and mechanical.
// ============================================================================

const std = @import("std");

~import "$std/io"

// Event that does a simple identity transformation
// This proves the API works - future tests will do actual transformations
// [comptime|transform] annotation makes this event participate in AST transformation
~[comptime|transform]event simple_transform {
    source: Source[Text],
    program_ast: *const Program
}
| transformed { program: *const Program }
| failed { error: []const u8 }

~proc simple_transform {
    // MVP: For now, just prove the signature compiles
    // The evaluate_comptime pass hasn't been implemented yet to actually
    // execute this, but the test captures what the API SHOULD look like

    // Future implementation will:
    // 1. Inspect source.text and source.scope.bindings
    // 2. Generate new AST nodes using ast_functional.zig
    // 3. Return transformed item

    // For now: Return the input item unchanged (identity transform)
    return .{ .transformed = .{ .program = program_ast } };
}

// Module-level invocation with Source block
// This should compile and prove the syntax works
~simple_transform [Text]{
    Hello from test 106!
    This Source block gets passed to simple_transform.
}

// Print success message
~std.io:println(text: "Test 106: Source with Item transformation syntax verified!")
