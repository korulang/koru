// ============================================================================
// VERIFIED REGRESSION TEST - DO NOT MODIFY WITHOUT DISCUSSION
// ============================================================================
// Test: Source Phantom Type Syntax
// Feature: Source blocks use [Type]{ } syntax to specify phantom types
// Verifies: Parser recognizes [...]{ } syntax and captures phantom annotations
// ============================================================================

~import "$std/io"

// ============================================================================
// TEST 1: Single Source with phantom type
// ============================================================================

~event renderPage { source: Source[HTML] }
| rendered { html: []const u8 }

~proc renderPage {
    // TODO: Actually parse and render the template
    return .{ .rendered = .{ .html = "<div>Test</div>" } };
}

// Single Source invocation with phantom type annotation
~renderPage [HTML]{
    <html>
        <body>
            <h1>Hello, World!</h1>
        </body>
    </html>
}
| rendered r |> std.io:println(text: r.html)

// ============================================================================
// TEST 2: Mixed parameters + Source
// ============================================================================

~event renderWithColor { color: []const u8, source: Source[HTML] }
| rendered { html: []const u8 }

~proc renderWithColor {
    return .{ .rendered = .{ .html = "<div>Colored</div>" } };
}

// Mixed: regular parameter + Source with phantom type
~renderWithColor(color: "red") [HTML]{
    <div style="color: ${color}">
        Hello!
    </div>
}
| rendered r |> std.io:println(text: r.html)

// ============================================================================
// TEST 3: Empty phantom type (no specific type constraint)
// ============================================================================

~event captureOpaque { source: Source[] }
| captured { text: []const u8 }

~proc captureOpaque {
    return .{ .captured = .{ .text = "Captured" } };
}

// Empty brackets = Source with no specific phantom type
~captureOpaque []{
    Some arbitrary text
    that doesn't conform to
    any specific format.
}
| captured c |> std.io:println(text: c.text)

