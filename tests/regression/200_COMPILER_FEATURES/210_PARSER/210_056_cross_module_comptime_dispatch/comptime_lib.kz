// Library module with a [comptime] event
//
// Mirrors the pattern from @korulang/postgres:
//   ~[comptime|norun]pub event sql { conninfo: ..., source: Source }
// Simplified to avoid Source parameter complexity.

const std = @import("std");

~[comptime|norun] pub event setup { config: []const u8 }
| ok { result: []const u8 }

~proc setup {
    std.debug.print("Comptime setup: {s}\n", .{config});
    return .{ .ok = .{ .result = "configured" } };
}
