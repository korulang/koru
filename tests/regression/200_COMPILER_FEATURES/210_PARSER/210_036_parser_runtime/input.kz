// Test: Parser as runtime library
// Parses Koru source code and inspects the AST at runtime
// This proves the parser is fully usable as a library!

~import "$std/parser"

const std = @import("std");

// Sample Koru code to parse
const SAMPLE_CODE =
    \\~event greet { name: []const u8 }
    \\| greeted {}
    \\
    \\~proc greet {
    \\    return .{ .greeted = .{} };
    \\}
;

// Void event to inspect AST - uses opaque pointer to avoid type issues
~event inspect_ast { ptr: *const anyopaque }

~proc inspect_ast {
    // Cast back to ParseResult
    const parser_impl = @import("parser");
    const parse_result: *const parser_impl.ParseResult = @ptrCast(@alignCast(ptr));

    std.debug.print("Parsed {} items\n", .{parse_result.source_file.items.len});

    // Find the event and proc declarations
    for (parse_result.source_file.items) |item| {
        switch (item) {
            .event_decl => |event| {
                std.debug.print("Found event: ", .{});
                for (event.path.segments) |seg| {
                    std.debug.print("{s}", .{seg});
                }
                std.debug.print("\n", .{});
            },
            .proc_decl => |proc_decl| {
                std.debug.print("Found proc: ", .{});
                for (proc_decl.path.segments) |seg| {
                    std.debug.print("{s}", .{seg});
                }
                std.debug.print("\n", .{});
            },
            else => {},
        }
    }
}

// Void event to report error
~event report_error { message: []const u8 }

~proc report_error {
    std.debug.print("Parse error: {s}\n", .{message});
}

~event main {}
| done {}

~proc main {
    // Parse the sample code using page_allocator
    // Use fully qualified event name
    ~std.parser:parse.source(source: SAMPLE_CODE, file_name: "sample.kz", allocator: std.heap.page_allocator)
    | parsed result |> inspect_ast(ptr: &result.ast)
    | parse_error err |> report_error(message: err.message)

    return .{ .done = .{} };
}

~main()
| done |> _
