// Test 837: --ast-json flag with stdlib imports
// Tests that koruc --ast-json can successfully parse files with stdlib imports
// ============================================================================

~import "$std/ccp"

const std = @import("std");

// Simple event that uses CCP
~event test { value: i32 }
| ok { result: i32 }

~proc test {
    return .{ .ok = .{ .result = value } };
}

// Simple flow
~test(value: 42)
| ok |> _
