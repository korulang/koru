// ============================================================================
// Test: --ast-json flag with stdlib imports
// Tests that koruc --ast-json can successfully parse files with stdlib imports
// ============================================================================

~import "$std/io"

const std = @import("std");

// Simple event
~event check { value: i32 }
| ok i32

~proc check {
    return .{ .ok = value };
}

// Simple flow
~check(value: 42)
| ok _ |> _
