// Test: Void events can be pruned at compile time
//
// With build config LOG_LEVEL=warn:
// - ~log.error("...") → emitted (error >= warn)
// - ~log.warn("...")  → emitted (warn >= warn)
// - ~log.info("...")  → PRUNED (info < warn)
// - ~log.debug("...") → PRUNED (debug < warn)
//
// The transform returns | pruned {} and the transform runner
// removes the invocation from the AST entirely.
// Zero runtime cost. The code doesn't exist in the binary.

~[comptime|transform]pub event log.* {
    event_name: []const u8,
    expr: Expression,
    source: Source,
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator,
}
| transformed { program: *const Program }
| pruned { }  // ← Transform runner removes void events when this is returned

~proc log.* {
    const ast = @import("ast");
    const ast_functional = @import("ast_functional");

    // Log level hierarchy (higher = more severe)
    const levels = [_]struct { name: []const u8, priority: u8 }{
        .{ .name = "debug", .priority = 0 },
        .{ .name = "info", .priority = 1 },
        .{ .name = "warn", .priority = 2 },
        .{ .name = "error", .priority = 3 },
    };

    // Build config threshold (would come from actual build config)
    const threshold: u8 = 2; // warn level

    // Extract level from event_name
    const level_name = event_name[4..];

    // Find level priority
    var level_priority: u8 = 0;
    for (levels) |l| {
        if (std.mem.eql(u8, level_name, l.name)) {
            level_priority = l.priority;
            break;
        }
    }

    // Prune if below threshold
    if (level_priority < threshold) {
        return .{ .pruned = {} };
    }

    // Emit logging code for levels at or above threshold
    const flow = if (item.* == .flow) &item.flow else return .{ .transformed = .{ .program = program } };

    const code = std.fmt.allocPrint(
        allocator,
        "std.debug.print(\"[{s}] {s}\\n\", .{{}});",
        .{ level_name, expr }
    ) catch unreachable;

    const inline_code_item = ast.Item{
        .inline_code = ast.InlineCode{
            .code = code,
            .location = flow.location,
            .module = allocator.dupe(u8, flow.module) catch unreachable,
        },
    };

    const maybe_new_program = ast_functional.replaceFlowRecursive(allocator, program, flow, inline_code_item) catch unreachable;
    if (maybe_new_program) |new_program| {
        const result = allocator.create(ast.Program) catch unreachable;
        result.* = new_program;
        return .{ .transformed = .{ .program = result } };
    }
    return .{ .transformed = .{ .program = program } };
}

// These should be EMITTED (at or above warn threshold)
~log.error("This is an error")
~log.warn("This is a warning")

// These should be PRUNED (below warn threshold)
~log.info("This will not exist in the binary")
~log.debug("Neither will this")
