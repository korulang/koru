// TEST: Multiple exec calls in a single transaction
//
// exec() consumes [!started|!active] and produces [active!]
// This means you can chain multiple execs - each one consumes
// the previous active state and produces a new one.
//
// EXPECTED: Compiles and runs successfully

~import "$app/db"

~app.db:connect(host: "localhost")
| ok c |>
    app.db:begin(conn: c)
    | ok t |>
        app.db:exec(tx: t, sql: "INSERT INTO users VALUES (1, 'alice')")
        | ok r1 |>
            app.db:exec(tx: r1, sql: "INSERT INTO users VALUES (2, 'bob')")
            | ok r2 |>
                app.db:exec(tx: r2, sql: "INSERT INTO users VALUES (3, 'charlie')")
                | ok r3 |>
                    app.db:commit(tx: r3)
                    | ok conn |>
                        app.db:close(conn: conn)
                        | ok |> _
                        | err _ |> _
                    | err _ |> _
                | err _ |> _
            | err _ |> _
        | err _ |> _
    | err _ |> _
| err _ |> _
