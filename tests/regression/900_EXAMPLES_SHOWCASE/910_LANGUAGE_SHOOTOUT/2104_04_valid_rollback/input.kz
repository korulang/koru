// TEST: Valid usage - connection → transaction → execute → rollback → close
//
// Rollback is also a valid way to end a transaction. The key is
// that it must be EXPLICIT - the programmer states their intent.
//
// EXPECTED: Compiles and runs successfully

~import "$app/db"

~app.db:connect(host: "localhost")
| ok c |>
    app.db:begin(conn: c.conn)
    | ok t |>
        app.db:exec(tx: t.tx, sql: "INSERT INTO users VALUES (1, 'alice')")
        | ok r |>
            // Decided to rollback instead of commit
            app.db:rollback(tx: r.tx)
            | ok conn |>
                app.db:close(conn: conn.conn)
                | ok _ |> _
                | err _ |> _
            | err _ |> _
        | err _ |> _
    | err _ |> _
| err _ |> _
