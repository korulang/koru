// Test: Escape + one borrow + cleanup

const std = @import("std");

const File = struct { handle: i32 };

~event open { path: []const u8 }
| opened *File[opened!]

~proc open {
    std.debug.print("Opening\n", .{});
    const f = std.heap.page_allocator.create(File) catch unreachable;
    f.* = File{ .handle = 42 };
    return .{ .opened = f };
}

~event use { file: *File[opened] }

~proc use {
    std.debug.print("Using\n", .{});
}

~event close { file: *File[!opened] }

~proc close {
    std.debug.print("Closing\n", .{});
    std.heap.page_allocator.destroy(file);
}

// Factory that escapes obligation
~event create { path: []const u8 }
| created *File[opened!]

~create = open(path: path)
| opened f |> created { resource: f.file }

// Main flow: create -> use -> cleanup
~create(path: "test.txt")
| created r |>
    use(file: r.resource)
    |>
        close(file: r.resource)
        |> _

pub fn main() void {}
