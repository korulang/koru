// TEST: Multiple disposal options - auto-discharge can't help, must be explicit
//
// When there are MULTIPLE ways to dispose a resource, the compiler
// REQUIRES you to be explicit. This catches logic bugs where you
// might have chosen the wrong disposal path.

~import "$std/control"

const std = @import("std");

const File = struct { handle: i32, dirty: bool };

~event open { path: []const u8 }
| opened *File[opened!]

~proc open {
    const f = std.heap.page_allocator.create(File) catch unreachable;
    f.* = File{ .handle = 42, .dirty = false };
    return .{ .opened = f };
}

~event write { file: *File[opened], data: []const u8 }

~proc write {
    file.dirty = true;
}

// Two different ways to close - user must choose!
~event close { file: *File[!opened] }

~proc close {
    std.debug.print("Close (no flush)\n", .{});
    std.heap.page_allocator.destroy(file);
}

~event flush_close { file: *File[!opened] }

~proc flush_close {
    std.debug.print("Flush and close\n", .{});
    std.heap.page_allocator.destroy(file);
}

const should_write = true;

// This should FAIL - auto-discharge can't choose between close and flush_close
~open(path: "test.txt")
| opened f |> std.control:if(should_write)
    | then |> write(file: f.file, data: "hello")
    | else |> _

pub fn main() void {}
