// BENCHMARK: Arc Overhead - Koru Version
//
// BULLETPROOF: Real work that can't be optimized away
// ZERO atomic operations. Just pointer passing.

~import "$std/control"

const std = @import("std");

const Resource = struct {
    id: usize,
    data: [64]u8,
};

const allocator = std.heap.c_allocator;

// Global accumulator (same pattern as Rust)
var grand_total: u64 = 0;

~event create { id: usize }
| created { r: *Resource[active!] }

~proc create {
    const r = allocator.create(Resource) catch unreachable;
    r.* = Resource{ .id = id, .data = [_]u8{@truncate(id)} ** 64 };
    return .{ .created = .{ .r = r } };
}

~event work { r: *Resource[active] }

~proc work {
    // Real work: sum the data array (same as Rust)
    var sum: u64 = 0;
    for (r.data) |byte| {
        sum += byte;
    }
    grand_total += sum;  // Accumulate like Rust
    std.mem.doNotOptimizeAway(sum);
}

~event destroy { r: *Resource[!active] }

~proc destroy {
    allocator.destroy(r);
}

~event print_result {}
| done {}

~proc print_result {
    std.debug.print("Koru: {} iterations, checksum: {}\n", .{N, grand_total});
    return .{ .done = .{} };
}

const N: usize = 1_000_000;

~for(0..N)
| each i |>
    create(id: i)
    | created r |>
        work(r: r.r) |> work(r: r.r) |> work(r: r.r) |> work(r: r.r) |> work(r: r.r) |> destroy(r: r.r)
| done |>
    print_result()

pub fn main() void {}
