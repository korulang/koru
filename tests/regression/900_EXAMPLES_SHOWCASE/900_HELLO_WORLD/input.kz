// Hello World - The Front Page Example
// This exact code appears on korulang.org
// If this test fails, the website shows broken code!

~import "$std/io"

const name = "World";
const debug = true;
const count: i32 = 42;

~std.io:print.blk {
    {% if debug %}[DEBUG] {% endif %}Hello, {{ name:s }}!
    The answer is {{ count:d }}.
}
