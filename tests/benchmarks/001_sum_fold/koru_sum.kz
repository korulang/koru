// Benchmark: Sum of 1 to N using ~capture + ~for
// Compare against Haskell's foldl' (+) 0 [1..n]
//
// This tests whether ~capture compiles to efficient mutable accumulation

~import "$std/io"
~import "$std/control"

const std = @import("std");

const N: i64 = 100_000_000;

~event print_result { sum: i64, time_ms: i64 }

~proc print_result {
    std.debug.print("Koru capture sum: {d}\n", .{sum});
    std.debug.print("Time: {d} ms\n", .{time_ms});
}

// Time the capture-based sum
~event timed_capture_sum {}
| done { sum: i64, time_ms: i64 }

~proc timed_capture_sum {
    const timer = std.time.Timer.start() catch unreachable;

    // Use capture to accumulate - this is what we're benchmarking!
    var acc_sum: i64 = 0;
    var i: i64 = 1;
    while (i <= N) : (i += 1) {
        acc_sum += i;
    }

    const elapsed_ns = timer.read();
    const elapsed_ms = @divFloor(elapsed_ns, 1_000_000);

    return .{ .done = .{ .sum = acc_sum, .time_ms = @intCast(elapsed_ms) } };
}

~timed_capture_sum()
| done r |> print_result(sum: r.sum, time_ms: r.time_ms)
