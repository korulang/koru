# ============================================================================
# Koru .gitignore - Whitelist Approach for Root Directory
# ============================================================================
# Strategy: Ignore everything at root by default, then whitelist essential files
# This prevents build artifacts and executables from being accidentally tracked

# Ignore everything at root level
/*

# Allow directories
!*/

# Allow dotfiles (but will be specific below)
!.*

# Globally allow Markdown files
!*.md
!**/*.md

# ============================================================================
# WHITELIST: Essential Files at Root
# ============================================================================

# Documentation
!README.md
!SPEC.md
!KORU.md
!STATUS.md
!CLAUDE.md
!DOCUMENTATION.md
!CONTRIBUTING.md

# Build configuration
!build.zig
!build.zig.zon
!koru.json

# Scripts
!run_regression.sh
!analyze_leaks.sh
!run_single_test.sh

# Node.js (tooling only - not runtime dependency)
!package.json

# Git files
!.gitignore
!.gitattributes

# ============================================================================
# Build Artifacts (Anywhere in Project)
# ============================================================================

.zig-cache/
zig-out/
*.o
*.hi
a.out

# Node.js dependencies (tooling only)
node_modules/

# ============================================================================
# Koru Studio
# ============================================================================

.koru-studio/

# ============================================================================
# Executables (Anywhere in Project)
# ============================================================================

# Root level executables (all caught by /* above, but be explicit)
/koruc
/koru
/koru_test
/koru_debug
/koruc_debug
/hello
/hello_*
/test_*
/output_*
/backend_tmp
/main

# Executables in examples/
examples/auth
examples/config
examples/hello
examples/hello_simple
examples/retry
examples/simple
examples/void_test
examples/test_union_return

# Executables in tests/integration/
tests/integration/01_basic_event
tests/integration/02_void_event
tests/integration/03_pipeline
tests/integration/04_nested_continuations
tests/integration/05_nested_continuations_full
tests/integration/06_void_events_full
tests/integration/07_namespaces
tests/integration/08_labels_loops

# Executables in showcase
examples/showcase/webserver/benchmark
examples/showcase/webserver/showcase

# Executables in tests/benchmarks/
tests/benchmarks/**/haskell_*
!tests/benchmarks/**/*.hs
tests/benchmarks/**/zig_baseline

# ============================================================================
# Generated Code (Anywhere in Project)
# ============================================================================

# Generated output files
*_output.zig
*_emitted.zig
output_*.zig

# Backup files
*_backup.zig
*_backup.kz

# ============================================================================
# Test Results and Temporary Files
# ============================================================================

# Regression test results (generated by scripts/generate-status.js)
status.json

# Test outputs
integration_results.txt
test_output.txt
*_results.txt

# Temporary test outputs
tests/scratchpad/

# Regression test configuration files (whitelisted at any depth)
!tests/regression/**/EXPECT
!tests/regression/**/SKIP
!tests/regression/**/MUST_COMPILE_KZ
!tests/regression/**/MUST_RUN
!tests/regression/**/expected.txt
!tests/regression/**/expected_output.txt
!tests/regression/**/expected_error.txt
!tests/regression/**/*.kz
!tests/regression/**/TODO
!tests/regression/**/BROKEN
!tests/regression/**/BUG_*
!tests/regression/**/post.sh
!tests/regression/**/*.c

# Regression test generated files (ignored at any depth)
tests/regression/**/backend
tests/regression/**/backend.zig
tests/regression/**/backend.err
tests/regression/**/compile_*.err
tests/regression/**/intermediate*
tests/regression/**/output
tests/regression/**/output*.zig
tests/regression/**/actual.txt
tests/regression/**/go_baseline
tests/regression/**/zig_baseline
tests/regression/**/test_backend.zig
tests/regression/**/koru_output

# Benchmark generated files (ignored at any depth)
tests/benchmarks/**/backend
tests/benchmarks/**/backend.zig
tests/benchmarks/**/backend_output_emitted.zig
tests/benchmarks/**/output_emitted.zig
tests/benchmarks/**/actual.txt

# ============================================================================
# Environment and IDE
# ============================================================================

.env
.claude/
CLAUDE.md
CLAUDE.md.template
package.json
test-results/
zig-out/
.agent/
temp_build.zig
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# OS Files
# ============================================================================

.DS_Store
Thumbs.db

# Prose local data
.claude/prose/
# Prose skill (auto-generated)
.claude/skills/flash/

# Koru generated files in examples
examples/**/backend.zig
examples/**/backend_output_emitted.zig
examples/**/build.zig
examples/**/build_backend.zig
examples/**/build_output.zig
examples/**/output_emitted.zig
